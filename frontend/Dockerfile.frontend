# Containerizes the existing AI-Studio-generated Vite frontend as-is (dev
# server), per backend-spec.md §7 — no rebuild of the app itself, just wiring
# it into the same docker-compose.yml as a service.
FROM node:20-slim
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm install
COPY . .
EXPOSE 3000
CMD ["npm", "run", "dev"]
